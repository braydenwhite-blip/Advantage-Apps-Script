function writerOfTheMonth() {
const tracker = ensureTrackerSheet_();
const lastRow = tracker.getLastRow();
if (lastRow < 2) return;
const now = today_();
const month = new Date(now.getFullYear(), now.getMonth() - 1, 1);
const end = new Date(now.getFullYear(), now.getMonth(), 0);
const vals = tracker.getRange(2, 1, lastRow - 1, CONFIG.COL_PUBLISHED_AT).getValues();
const scores = {};
vals.forEach(row => {
const writer = (row[CONFIG.COL_WRITER-1]||"").toString().trim();
const signupDate = row[CONFIG.COL_SIGNUP_DATE-1];
const draftSubmitted = row[CONFIG.COL_DRAFT_SUBMITTED-1] === true;
const submittedAt = row[CONFIG.COL_DRAFT_SUBMITTED_AT-1];
const draftDue = row[CONFIG.COL_DRAFT_DUE-1];
const email = (row[CONFIG.COL_EMAIL-1]||"").toString().trim();
if (!writer || !(signupDate instanceof Date)) return;
if (signupDate < month || signupDate > end) return;
if (!draftSubmitted) return;
if (!scores[writer]) scores[writer] = { count: 0, onTime: 0, email };
scores[writer].count++;
if (submittedAt instanceof Date && draftDue instanceof Date && submittedAt <= draftDue) {
scores[writer].onTime++;
}
});
if (!Object.keys(scores).length) return;
const winner = Object.entries(scores)
.sort((a, b) => (b[1].count * 2 + b[1].onTime) - (a[1].count * 2 + a[1].onTime))[0];
const [name, data] = winner;
const monthName = fmtMon_(month);
// Email winner
const body = emailShell_(`Writer of the Month — ${monthName}`, {label:"WOTM", bg:"#7c3aed", fg:"#fff"}, `
