* TRACKER ROW HELPERS
***************/
function findTrackerRowByCycleId_(tracker, cycleId) {
const lastRow = tracker.getLastRow();
if (lastRow < 2) return -1;
const vals = tracker.getRange(2, CONFIG.COL_CYCLE_ID, lastRow - 1, 1).getValues();
for (let i = 0; i < vals.length; i++) {
if ((vals[i][0]||"").toString().trim() === cycleId) return i + 2;
}
return -1;
}
function parseCycleIdFromAssignment_(label) {
const m = label.match(/([A-Z]{1,10}-\d{8}-\d{3})/);
if (m) return m[1];
throw new Error(`Could not extract Cycle ID from: "${label}"`);
}
// All tracker rows for a writer (by name, case-insensitive)
function findAllRowsForWriter_(tracker, writerName) {
const lastRow = tracker.getLastRow();
if (lastRow < 2) return [];
const vals = tracker.getRange(2, 1, lastRow - 1, CONFIG.COL_PUBLISHED_AT).getValues();
return vals.reduce((acc, row, i) => {
if ((row[0]||"").toString().trim().toLowerCase() === writerName.toLowerCase()) acc.push({ row, rowNum: i + 2 });
return acc;
}, []);
}
function countPublishedForWriter_(tracker, writerName) {
return findAllRowsForWriter_(tracker, writerName)
.filter(({ row }) => row[CONFIG.COL_DRAFT_SUBMITTED - 1] === true && row[CONFIG.COL_PUBLISHED_LINK - 1]).length;
}
function countOnTimeForWriter_(tracker, writerName) {
return findAllRowsForWriter_(tracker, writerName)
.filter(({ row }) => (row[CONFIG.COL_ON_TIME_COUNT - 1] || 0) > 0).length;
}
// Recalculate and update streak for writer in a given row
function recalcStreak_(tracker, writerName) {
const rows = findAllRowsForWriter_(tracker, writerName)
.filter(({ row }) => row[CONFIG.COL_DRAFT_SUBMITTED - 1] === true)
.sort((a, b) => new Date(a.row[CONFIG.COL_SIGNUP_DATE - 1]) - new Date(b.row[CONFIG.COL_SIGNUP_DATE - 1]));
let streak = 0;
for (let i = rows.length - 1; i >= 0; i--) {
const row = rows[i].row;
const draftSubmittedAt = row[CONFIG.COL_DRAFT_SUBMITTED_AT - 1];
const draftDue = row[CONFIG.COL_DRAFT_DUE - 1];
if (draftSubmittedAt instanceof Date && draftDue instanceof Date && draftSubmittedAt <= draftDue) {
streak++;
} else {
break;
}
}
// Write streak to most recent row
if (rows.length > 0) {
tracker.getRange(rows[rows.length - 1].rowNum, CONFIG.COL_STREAK).setValue(streak);
}
return streak;
}
