/***************
* TRIGGER SETUP — run once
***************/
function createTriggers() {
ScriptApp.getProjectTriggers().forEach(t => {
const fn = t.getHandlerFunction();
if ([
"handleAllFormSubmits","sendDailyReminders","sendDailyDigest",
"syncAllForms","generateWeeklyReport","writerOfTheMonth",
"writerSpotlight","sendInactivityReport","archiveCompletedCycles",
"processOnboardingQueue_"
].includes(fn)) ScriptApp.deleteTrigger(t);
});
const ss = SpreadsheetApp.getActive();
// Form submissions
ScriptApp.newTrigger("handleAllFormSubmits").forSpreadsheet(ss).onFormSubmit().create();
// 6am — form sync
ScriptApp.newTrigger("syncAllForms").timeBased().everyDays(1).atHour(6).create();
// 7am — daily digest to admin
ScriptApp.newTrigger("sendDailyDigest").timeBased().everyDays(1).atHour(7).create();
// 8am — writer reminders + ghost detection + "we miss you"
ScriptApp.newTrigger("sendDailyReminders").timeBased().everyDays(1).atHour(8).create();
// Monday 9am — weekly report + leaderboard update
ScriptApp.newTrigger("generateWeeklyReport").timeBased().onWeekDay(ScriptApp.WeekDay.MONDAY).atHour(9).create();
// 1st of each month — writer of the month + spotlight + inactivity report
ScriptApp.newTrigger("writerOfTheMonth").timeBased().onMonthDay(1).atHour(10).create();
ScriptApp.newTrigger("writerSpotlight").timeBased().onMonthDay(1).atHour(10).create();
ScriptApp.newTrigger("sendInactivityReport").timeBased().onMonthDay(1).atHour(11).create();
// 15th of each month — auto-archive old published cycles
ScriptApp.newTrigger("archiveCompletedCycles").timeBased().onMonthDay(15).atHour(6).create();
Logger.log("All triggers created successfully.");
}
 
Logger.log("All forms synced.");
}
