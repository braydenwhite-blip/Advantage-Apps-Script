* manualMarkDraftSubmitted("CYCLEID", "https://docs.google.com/...")
***************/
function manualMarkIdeasSubmitted(cycleId, idea1Title, idea1Pitch, idea2Title, idea2Pitch) {
const tracker = ensureTrackerSheet_();
const rowNum = findTrackerRowByCycleId_(tracker, cycleId);
if (rowNum === -1) { Logger.log(`manualMarkIdeasSubmitted: not found: ${cycleId}`); return; }
if (idea1Title) tracker.getRange(rowNum, CONFIG.COL_IDEA1_TITLE).setValue(idea1Title);
if (idea1Pitch) tracker.getRange(rowNum, CONFIG.COL_IDEA1_PITCH).setValue(idea1Pitch);
if (idea2Title) tracker.getRange(rowNum, CONFIG.COL_IDEA2_TITLE).setValue(idea2Title);
if (idea2Pitch) tracker.getRange(rowNum, CONFIG.COL_IDEA2_PITCH).setValue(idea2Pitch);
tracker.getRange(rowNum, CONFIG.COL_IDEAS_SUBMITTED_AT).setValue(new Date());
tracker.getRange(rowNum, CONFIG.COL_IDEAS_SUBMITTED).setValue(true);
const ideaDue = tracker.getRange(rowNum, CONFIG.COL_IDEAS_DUE).getValue();
if (ideaDue instanceof Date && new Date() <= ideaDue) {
const prev = tracker.getRange(rowNum, CONFIG.COL_ON_TIME_COUNT).getValue() || 0;
tracker.getRange(rowNum, CONFIG.COL_ON_TIME_COUNT).setValue(Number(prev) + 1);
} else {
const prev = tracker.getRange(rowNum, CONFIG.COL_LATE_COUNT).getValue() || 0;
tracker.getRange(rowNum, CONFIG.COL_LATE_COUNT).setValue(Number(prev) + 1);
}
clearLateSent_(cycleId, "ideas");
syncIdeaFormAssignments_();
recordWeeklyAnalytics_("ideas", 1);
Logger.log(`Manually marked ideas submitted: ${cycleId}`);
}
function manualMarkDraftSubmitted(cycleId, draftLink) {
const tracker = ensureTrackerSheet_();
const rowNum = findTrackerRowByCycleId_(tracker, cycleId);
if (rowNum === -1) { Logger.log(`manualMarkDraftSubmitted: not found: ${cycleId}`); return; }
const writer = tracker.getRange(rowNum, CONFIG.COL_WRITER).getValue();
const email = tracker.getRange(rowNum, CONFIG.COL_EMAIL).getValue();
if (draftLink) tracker.getRange(rowNum, CONFIG.COL_DRAFT_LINK).setValue(draftLink);
tracker.getRange(rowNum, CONFIG.COL_DRAFT_SUBMITTED_AT).setValue(new Date());
tracker.getRange(rowNum, CONFIG.COL_DRAFT_SUBMITTED).setValue(true);
const draftDue = tracker.getRange(rowNum, CONFIG.COL_DRAFT_DUE).getValue();
if (draftDue instanceof Date && new Date() <= draftDue) {
const prev = tracker.getRange(rowNum, CONFIG.COL_ON_TIME_COUNT).getValue() || 0;
tracker.getRange(rowNum, CONFIG.COL_ON_TIME_COUNT).setValue(Number(prev) + 1);
} else {
const prev = tracker.getRange(rowNum, CONFIG.COL_LATE_COUNT).getValue() || 0;
tracker.getRange(rowNum, CONFIG.COL_LATE_COUNT).setValue(Number(prev) + 1);
}
clearLateSent_(cycleId, "draft");
recalcStreak_(tracker, writer);
upsertRoster_(writer, email, tracker);
syncDraftFormAssignments_();
recordWeeklyAnalytics_("drafts", 1);
Logger.log(`Manually marked draft submitted: ${cycleId}`);
}
