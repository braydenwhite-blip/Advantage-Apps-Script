/***************
* DATE + FORMATTING HELPERS
***************/
function tz_() { return Session.getScriptTimeZone(); }
function ymd_(d) { return Utilities.formatDate(d, tz_(), "yyyy-MM-dd"); }
function fmtDate_(d) { return Utilities.formatDate(d, tz_(), "EEEE, MMMM d, yyyy"); }
function fmtShort_(d){ return Utilities.formatDate(d, tz_(), "M/d/yyyy"); }
function fmtMon_(d) { return Utilities.formatDate(d, tz_(), "MMMM yyyy"); }
function today_() { const d = new Date(); return new Date(d.getFullYear(), d.getMonth(), d.getDate()); }
function daysUntil_(d) {
const ms = new Date(d.getFullYear(), d.getMonth(), d.getDate()) - today_();
return Math.round(ms / 86400000);
}
function daysSince_(d) { return -daysUntil_(d); }
/***************
* LATE-NOTICE THROTTLE HELPERS
* Prevents the same "overdue" email from going out every single day.
* Uses PropertiesService to record when each late notice was last sent.
* Key format: LATE_<cycleId>_<kind>   value: yyyy-MM-dd of last send
***************/
function wasLateSentRecently_(cycleId, kind) {
const props = PropertiesService.getScriptProperties();
const lastSent = props.getProperty(`LATE_${cycleId}_${kind}`);
if (!lastSent) return false;
const parsed = parseDate_(lastSent);
return parsed && daysSince_(parsed) < 7;
}
function recordLateSent_(cycleId, kind) {
PropertiesService.getScriptProperties().setProperty(`LATE_${cycleId}_${kind}`, ymd_(today_()));
}
function clearLateSent_(cycleId, kind) {
PropertiesService.getScriptProperties().deleteProperty(`LATE_${cycleId}_${kind}`);
}
function initials_(name) {
return name.trim().split(/\s+/).filter(Boolean).map(w => w[0].toUpperCase()).join("");
}
}
/***************
* STATUS FORMULA
***************/
function statusFormula_(r) {
return `=IF($A${r}="","",`
+ `IF($Y${r}<>"","✅ Published",`
+ `IF($P${r}=TRUE,"📝 Editing",`
+ `IF(AND($N${r}=TRUE,$P${r}=FALSE),IF(TODAY()>$G${r},"🔴 Draft Late","🟡 Draft Pending"),`
+ `IF(AND($H${r}=TRUE,$N${r}=FALSE),"⏳ Awaiting Approval",`
+ `IF($H${r}=FALSE,IF(TODAY()>$F${r},"🔴 Ideas Late","🔵 Ideas Pending"),""))))))`;
}
