function recordWeeklyAnalytics_(field, increment) {
try {
const sheet = ensureAnalyticsSheet_();
const weekOf = ymd_(getWeekStart_());
const lastRow = sheet.getLastRow();
let targetRow = -1;
if (lastRow >= 2) {
const dates = sheet.getRange(2, 1, lastRow - 1, 1).getValues();
for (let i = 0; i < dates.length; i++) {
if (ymd_(dates[i][0]) === weekOf) { targetRow = i + 2; break; }
}
}
const fieldMap = { signups: 2, ideas: 3, drafts: 4, published: 5, lateIdeas: 6, lateDrafts: 7 };
const col = fieldMap[field];
if (!col) return;
if (targetRow === -1) {
const newRow = new Array(9).fill(0);
newRow[0] = weekOf;
newRow[col - 1] = increment;
sheet.appendRow(newRow);
} else {
const current = sheet.getRange(targetRow, col).getValue() || 0;
sheet.getRange(targetRow, col).setValue(Number(current) + increment);
}
} catch(e) { /* non-critical */ }
}
function getWeekStart_() {
const d = today_();
const day = d.getDay();
return new Date(d.getTime() - day * 86400000);
}
