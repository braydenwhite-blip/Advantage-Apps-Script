function findRosterRow_(roster, writerName) {
const lastRow = roster.getLastRow();
if (lastRow < 2) return -1;
const vals = roster.getRange(2, 1, lastRow - 1, 1).getValues();
for (let i = 0; i < vals.length; i++) {
if ((vals[i][0]||"").toString().trim().toLowerCase() === writerName.toLowerCase()) return i + 2;
}
return -1;
}
function upsertRoster_(writerName, email, tracker) {
const roster = ensureRosterSheet_();
const rowNum = findRosterRow_(roster, writerName);
const rows = findAllRowsForWriter_(tracker, writerName);
const published = rows.filter(({ row }) => row[CONFIG.COL_PUBLISHED_LINK - 1]).length;
const totalDone = rows.filter(({ row }) => row[CONFIG.COL_DRAFT_SUBMITTED - 1] === true).length;
const onTime = rows.filter(({ row }) => {
const sub = row[CONFIG.COL_DRAFT_SUBMITTED_AT - 1];
const due = row[CONFIG.COL_DRAFT_DUE - 1];
return sub instanceof Date && due instanceof Date && sub <= due;
}).length;
const streak = recalcStreak_(tracker, writerName);
const types = [...new Set(rows.map(({ row }) => row[CONFIG.COL_TYPE - 1]).filter(Boolean))].join(", ");
const lastActive = rows.length > 0
? rows.sort((a,b) => new Date(b.row[CONFIG.COL_SIGNUP_DATE-1]) - new Date(a.row[CONFIG.COL_SIGNUP_DATE-1]))[0].row[CONFIG.COL_SIGNUP_DATE-1]
: new Date();
const status = totalDone >= CONFIG.HALL_OF_FAME_COUNT ? "🏆 Hall of Fame"
: totalDone > 0 ? "Active"
: "New";
const data = [writerName, email, null, status, published, pct_(onTime, totalDone), streak, lastActive, types];
if (rowNum === -1) {
data[2] = new Date(); // Join Date
roster.appendRow(data);
} else {
const joinDate = roster.getRange(rowNum, 3).getValue();
data[2] = joinDate || new Date();
roster.getRange(rowNum, 1, 1, data.length).setValues([data]);
}
}
