function calculateHealthScore() {
const tracker = ensureTrackerSheet_();
const lastRow = tracker.getLastRow();
if (lastRow < 2) return 0;
const vals = tracker.getRange(2, 1, lastRow - 1, CONFIG.COL_PUBLISHED_AT).getValues();
const active = vals.filter(r => r[CONFIG.COL_WRITER-1] && !r[CONFIG.COL_PUBLISHED_LINK-1]);
if (!active.length) return 100;
const onTime = active.filter(r => {
const sub = r[CONFIG.COL_DRAFT_SUBMITTED_AT-1];
const due = r[CONFIG.COL_DRAFT_DUE-1];
return sub instanceof Date && due instanceof Date && sub <= due;
}).length;
const submitted = active.filter(r => r[CONFIG.COL_DRAFT_SUBMITTED-1] === true).length;
const late = active.filter(r =>
(!r[CONFIG.COL_IDEAS_SUBMITTED-1] && r[CONFIG.COL_IDEAS_DUE-1] instanceof Date && daysUntil_(r[CONFIG.COL_IDEAS_DUE-1]) < 0) ||
(r[CONFIG.COL_IDEA_APPROVED-1] === true && !r[CONFIG.COL_DRAFT_SUBMITTED-1] && r[CONFIG.COL_DRAFT_DUE-1] instanceof Date && daysUntil_(r[CONFIG.COL_DRAFT_DUE-1]) < 0)
).length;
const submissionRate = active.length > 0 ? submitted / active.length : 1;
const onTimeRate = submitted > 0 ? onTime / submitted : 1;
const lateRate = active.length > 0 ? late / active.length : 0;
const score = Math.round((submissionRate * 40 + onTimeRate * 40 + (1 - lateRate) * 20));
// Log it to analytics
const analyticsSheet = ensureAnalyticsSheet_();
const weekOf = ymd_(getWeekStart_());
const aLastRow = analyticsSheet.getLastRow();
if (aLastRow >= 2) {
const dates = analyticsSheet.getRange(2, 1, aLastRow - 1, 1).getValues();
for (let i = 0; i < dates.length; i++) {
if (ymd_(dates[i][0]) === weekOf) {
analyticsSheet.getRange(i + 2, 9).setValue(active.length); // active writers col
break;
}
}
}
Logger.log(`Pipeline Health Score: ${score}/100`);
return score;
}
/***************
* END OF YEAR REPORT — call manually: sendEndOfYearReport()
***************/
function sendEndOfYearReport() {
const tracker = ensureTrackerSheet_();
const lastRow = tracker.getLastRow();
const pubSheet = ensurePublishedSheet_();
const ssUrl = SpreadsheetApp.getActive().getUrl();
const year = new Date().getFullYear();
const vals = lastRow >= 2 ? tracker.getRange(2, 1, lastRow - 1, CONFIG.COL_PUBLISHED_AT).getValues() : [];
const archive = SpreadsheetApp.getActive().getSheetByName(CONFIG.ARCHIVE_SHEET);
const allVals = archive ? [...vals, ...(archive.getLastRow() >= 2 ? archive.getRange(2,1,archive.getLastRow()-1, CONFIG.TRACKER_HEADERS.length).getValues() : [])] : vals;
const yearVals = allVals.filter(r => {
const d = r[CONFIG.COL_SIGNUP_DATE-1];
return d instanceof Date && d.getFullYear() === year;
});
const uniqueWriters = [...new Set(yearVals.map(r => r[CONFIG.COL_WRITER-1]).filter(Boolean))];
const published = yearVals.filter(r => r[CONFIG.COL_PUBLISHED_LINK-1]).length;
const onTime = yearVals.filter(r => {
const sub = r[CONFIG.COL_DRAFT_SUBMITTED_AT-1];
const due = r[CONFIG.COL_DRAFT_DUE-1];
return sub instanceof Date && due instanceof Date && sub <= due;
}).length;
const totalDrafts = yearVals.filter(r => r[CONFIG.COL_DRAFT_SUBMITTED-1] === true).length;
// Most productive month
const monthCounts = {};
yearVals.filter(r => r[CONFIG.COL_PUBLISHED_LINK-1]).forEach(r => {
const d = r[CONFIG.COL_PUBLISHED_AT-1];
if (!(d instanceof Date)) return;
const m = Utilities.formatDate(d, tz_(), "MMMM");
monthCounts[m] = (monthCounts[m] || 0) + 1;
});
const bestMonth = Object.entries(monthCounts).sort((a,b) => b[1]-a[1])[0];
// Top writers
const writerCounts = {};
yearVals.filter(r => r[CONFIG.COL_PUBLISHED_LINK-1]).forEach(r => {
const w = (r[CONFIG.COL_WRITER-1]||"").trim();
writerCounts[w] = (writerCounts[w] || 0) + 1;
});
const topWriters = Object.entries(writerCounts).sort((a,b) => b[1]-a[1]).slice(0,5);
const body = emailShell_(`${year} Year in Review`, {label:"Annual Report", bg:"#0f1923", fg:"#fff"}, `
<div style="text-align:center;padding:24px;background:#f9f8f5;border-radius:10px;margin-bottom:20px;">
<div style="font-size:36px;font-weight:700;color:#0f1923;">${year}</div>
<div style="font-size:14px;color:#555;">The Advantage Annual Report</div>
</div>
<div style="display:flex;flex-wrap:wrap;margin-bottom:20px;">
${pill_("Total Writers", uniqueWriters.length)}
${pill_("Articles Published", published)}
${pill_("On-Time Rate", pct_(onTime, totalDrafts))}
${bestMonth ? pill_("Best Month", `${bestMonth[0]} (${bestMonth[1]} published)`) : ""}
</div>
<div style="margin-bottom:16px;">
<div style="font-weight:700;margin-bottom:6px;">Top contributors</div>
<ol style="margin:0;padding-left:18px;font-size:13px;line-height:2;">
${topWriters.map(([w,n]) => `<li><b>${w}</b> — ${n} article${n !== 1 ? "s" : ""}</li>`).join("")}
</ol>
</div>
${button_("Open Tracker", ssUrl, "#0f1923")}
`);
sendAdminEmail_(`The Advantage — ${year} Year in Review`, body);
Logger.log(`Year in review sent for ${year}.`);
}
