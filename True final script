/***************
* LEADERBOARD (refresh monthly or on-demand)
***************/
function updateLeaderboard_() {
const tracker = ensureTrackerSheet_();
const leaderboard = ensureLeaderboardSheet_();
const lastRow = tracker.getLastRow();
if (lastRow < 2) return;
const vals = tracker.getRange(2, 1, lastRow - 1, CONFIG.COL_PUBLISHED_AT).getValues();
// Aggregate by writer
const writerMap = {};
vals.forEach(row => {
const writer = (row[CONFIG.COL_WRITER-1]||"").toString().trim();
if (!writer) return;
if (!writerMap[writer]) writerMap[writer] = { published: 0, onTime: 0, total: 0, streak: 0 };
if (row[CONFIG.COL_PUBLISHED_LINK-1]) writerMap[writer].published++;
if (row[CONFIG.COL_DRAFT_SUBMITTED-1] === true) {
writerMap[writer].total++;
const sub = row[CONFIG.COL_DRAFT_SUBMITTED_AT-1];
const due = row[CONFIG.COL_DRAFT_DUE-1];
if (sub instanceof Date && due instanceof Date && sub <= due) writerMap[writer].onTime++;
}
const s = Number(row[CONFIG.COL_STREAK-1] || 0);
if (s > writerMap[writer].streak) writerMap[writer].streak = s;
});
const sorted = Object.entries(writerMap)
.map(([name, d]) => [name, d.published, pct_(d.onTime, d.total), d.streak, d.published >= CONFIG.HALL_OF_FAME_COUNT ? "🏆 Hall of Fame" : "Active"])
.sort((a, b) => b[1] - a[1]);
// Clear and rewrite
const lb = leaderboard;
if (lb.getLastRow() > 1) lb.getRange(2, 1, lb.getLastRow() - 1, 6).clearContent();
sorted.forEach((row, i) => {
lb.appendRow([i + 1, ...row]);
});
// Highlight top 3
sorted.slice(0, 3).forEach((_, i) => {
const colors = ["#fefce8", "#f1f5f9", "#fff7ed"];
lb.getRange(i + 2, 1, 1, 6).setBackground(colors[i]);
});
}
